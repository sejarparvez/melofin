# Copy to .env (or export these yourself) and adjust as needed.
# NOTE: melofin currently searches/resolves streams via `yt-dlp` and plays
# them via a headless `mpv` subprocess (see doc/GUIDE.md's note on this vs.
# the original rustypipe/libmpv-rs plan). There is currently no botguard /
# rustypipe cookie config to set, since that backend isn't wired up in code
# yet — remove this note if/when that changes.

# Logging verbosity: error | warn | info | debug | trace
# Can also scope per-module, e.g. RUST_LOG=melofin=debug,mpris_server=warn
RUST_LOG=info
